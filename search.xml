        <content type="html"><![CDATA[<h3 id="1-整数逆序"><a href="#1-整数逆序" class="headerlink" title="1.整数逆序"></a>1.整数逆序</h3><pre class="line-numbers language-none"><code class="language-none">#include &lt;stdio.h&gt;int main()&#123;    int x;    int result &#x3D; 0;    printf(&quot;请输入一个整数：&quot;);    scanf_s(&quot;%d&quot;, &amp;x);    while (x !&#x3D; 0)    &#123;        result &#x3D; result * 10 + x % 10;        x &#x3D; x &#x2F; 10;    &#125;    printf(&quot;%d&quot;, result);    printf(&quot;\n&quot;);    return 0;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre><h3 id="2-统计英文单词，大写字母，小写字母个数"><a href="#2-统计英文单词，大写字母，小写字母个数" class="headerlink" title="2.统计英文单词，大写字母，小写字母个数"></a>2.统计英文单词，大写字母，小写字母个数</h3><pre class="line-numbers language-none"><code class="language-none">#include&lt;stdio.h&gt;#include&lt;ctype.h&gt;#include&lt;string.h&gt;int main()&#123;char st[] &#x3D; &#123;&quot;Encryption has long been used by militaries and governments to facilitate secret \communication.It is now commonly used in protecting information within many\kinds of civilian systems.For example, the Computer Security Institute reported\that in 2007, 71 % of companies surveyed utilized encryption for some of their\data in transit, and 53 % utilized encryption for some of their data in storage&quot;&#125;;char mark1 &#x3D; st[0];&#x2F;&#x2F;先标char mark2 &#x3D; &#39; &#39;;&#x2F;&#x2F;后标int num &#x3D; 0,num2 &#x3D; 0, num3 &#x3D; 0;size_t size &#x3D; strlen(st);&#x2F;&#x2F;文章长度for (int x &#x3D; 0; x &lt; size &amp;&amp; (mark1 !&#x3D; &#39;\n&#39;); x++)&#x2F;&#x2F;两个标记从开头扫描整篇文章&#123;mark1 &#x3D; st[x];if (mark1 &#x3D;&#x3D; &#39;\n&#39;)break;else if ((isalpha(mark1) &amp;&amp; (mark2 &#x3D;&#x3D; &#39; &#39;)))&#x2F;&#x2F;若标1是字母而标2是空格num++;&#x2F;&#x2F;单词+1if (isupper(mark1))num2++;&#x2F;&#x2F;大写+1if (islower(mark1))num3++;&#x2F;&#x2F;小写+1mark2 &#x3D; mark1;&#x2F;&#x2F;使两个标记始终是相邻标记，标1在先，标2在后&#125;printf(&quot;单词个数为%d\n大写字母个数为%d\n小写字母个数为%d&quot;, num,num2,num3);&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre><h3 id="3-三个嫌疑犯在法官面前各执一词，甲说：乙在说谎；乙说：丙在说谎；丙说：甲乙两人都在说谎。法官为了难，甲乙丙三人到底谁在说谎，谁说的是真话？"><a href="#3-三个嫌疑犯在法官面前各执一词，甲说：乙在说谎；乙说：丙在说谎；丙说：甲乙两人都在说谎。法官为了难，甲乙丙三人到底谁在说谎，谁说的是真话？" class="headerlink" title="3.三个嫌疑犯在法官面前各执一词，甲说：乙在说谎；乙说：丙在说谎；丙说：甲乙两人都在说谎。法官为了难，甲乙丙三人到底谁在说谎，谁说的是真话？"></a>3.三个嫌疑犯在法官面前各执一词，甲说：乙在说谎；乙说：丙在说谎；丙说：甲乙两人都在说谎。法官为了难，甲乙丙三人到底谁在说谎，谁说的是真话？</h3><pre class="line-numbers language-none"><code class="language-none">#include &lt;stdio.h&gt; int main(int argc, char *argv[]) &#123; int a,b,c; for(a&#x3D;0; a&lt;2; a++) for(b&#x3D;0; b&lt;2; b++) for(c&#x3D;0; c&lt;2; c++) if((a&amp;&amp;!b || !a&amp;&amp;b) &amp;&amp; (b&amp;&amp;!c || !b&amp;&amp;c) &amp;&amp; (c &amp;&amp;a+b &#x3D;&#x3D; 0 || !c&amp;&amp;a+b !&#x3D; 0))&#123;printf(&quot;甲说的话是%s\n&quot;,a?&quot;真&quot;:&quot;假&quot;);printf(&quot;乙说的话是%s\n&quot;,b?&quot;真&quot;:&quot;假&quot;);printf(&quot;丙说的话是%s\n&quot;,c?&quot;真&quot;:&quot;假&quot;);&#125;&#125;<span aria-hidden="true" class="line-numbers-rows"><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span><span></span></span></code></pre>]]></content>
      
      
